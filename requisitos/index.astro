---
import '../../styles/global.css';
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const todos = await getCollection('juegos');

const niveles = [
  { slug: 'altos', nombre: 'Requisitos Altos', desc: 'Para PCs con hardware potente y de última generación.' },
  { slug: 'medios', nombre: 'Requisitos Medios', desc: 'Equipos con especificaciones estándar actuales.' },
  { slug: 'minimos', nombre: 'Requisitos Mínimos', desc: 'Juegos ligeros, ideales para PCs modestas.' },
].map((n) => ({
  ...n,
  total: todos.filter((j) => j.data.nivelRequisitos === n.slug).length,
}));
---

<Layout title="Requisitos de Sistema | yizugames">
  <div class="encabezado-listado">
    <h1>Requisitos de Sistema</h1>
    <p>Filtra los juegos según lo que tu PC pueda mover.</p>
  </div>

  <div class="grid-tiles">
    {niveles.map((n) => (
      <a class="tile-enlace" href={`/requisitos/${n.slug}`}>
        <h3>{n.nombre}</h3>
        <span>{n.desc}</span>
        <span>{n.total} juego{n.total === 1 ? '' : 's'}</span>
      </a>
    ))}
  </div>
</Layout>

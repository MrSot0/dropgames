---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import GameCard from '../components/GameCard.astro';

// 1. Lógica de paginación automática
export async function getStaticPaths({ paginate }) {
  const todos = await getCollection('juegos');
  
  const juegosOrdenados = [...todos].sort((a, b) => 
    b.data.fecha.valueOf() - a.data.fecha.valueOf()
  );

  return paginate(juegosOrdenados, { pageSize: 9 });
}

const { page } = Astro.props;

// 🎯 MEJORA SEO 1: Títulos dinámicos para evitar duplicados en Google
const baseTitle = "DropGames | Descargar Juegos de PC y Android Gratis";
const titleSEO = page.currentPage > 1 
  ? `${baseTitle} - Página ${page.currentPage}` 
  : baseTitle;

// Supongamos que quieres mostrar tus mejores juegos en el Sidebar para pasarles "autoridad link equity"
const todosLosJuegos = await getCollection('juegos');
const juegosTop = todosLosJuegos.slice(0, 5); // Obtiene los 5 primeros para el Top
---

<Layout 
  title={titleSEO} 
  prevPage={page.url.prev} 
  nextPage={page.url.next}
>
  <main class="contenedor-principal">
    
    <section class="seccion-recientes">
      {page.currentPage === 1 && (
        <h1 class="sr-only">DropGames - Tu rincón para descargar videojuegos de PC gratis</h1>
      )}
      
      <h2 class="titulo-seccion">Novedades Recientes</h2>
      
      <div class="grid-videojuegos">
        {page.data.map((juego) => <GameCard juego={juego} />)}
      </div>

      <nav class="pagination-ui" aria-label="Paginación de juegos">
        {page.url.prev && <a href={page.url.prev} class="nav-btn">« Anterior</a>}
        
        <span class="page-numbers" aria-current="page">Página {page.currentPage} de {page.lastPage}</span>
        
        {page.url.next && <a href={page.url.next} class="nav-btn">Siguiente »</a>}
      </nav>
    </section>

    <aside class="sidebar-top">
      
      <div class="widget-top-juegos">
        <h3 class="titulo-widget">🔥 Juegos más buscados</h3>
        <ul class="lista-top">
          {juegosTop.map((juego) => (
            <li>
              <a href={`/juegos/${juego.slug}`}>
                <span>{juego.data.titulo}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="sidebar-ads">
      
        <div class="ad-slot ad-sidebar-small" style="text-align: center; margin-bottom: 1rem; overflow: hidden;">
          <iframe 
            loading="lazy"
            srcdoc="
              <body style='margin:0; padding:0; text-align:center;'>
                <div id='container-decd1f4598bf4831bd5806c2f6da54ca'></div>
                <script async='async' data-cfasync='false' src='https://pl30310791.effectivecpmnetwork.com/decd1f4598bf4831bd5806c2f6da54ca/invoke.js'></script>
              </body>"
            style="width: 100%; height: 100px; border: none; scrolling: no; overflow: hidden;">
          </iframe>
        </div>

        <div class="ad-slot ad-sidebar-rect" style="text-align: center; margin-bottom: 1rem; overflow: hidden;">
          <iframe 
            loading="lazy"
            srcdoc="
              <body style='margin:0; padding:0; text-align:center;'>
                <div id='container-decd1f4598bf4831bd5806c2f6da54ca'></div>
                <script async='async' data-cfasync='false' src='https://pl30310791.effectivecpmnetwork.com/decd1f4598bf4831bd5806c2f6da54ca/invoke.js'></script>
              </body>"
            style="width: 100%; height: 390px; border: none; scrolling: no; overflow: hidden;">
          </iframe>
        </div>
        
        <div class="ad-slot ad-sidebar-tall" style="text-align: center; overflow: hidden;">
          <iframe 
            loading="lazy"
            srcdoc="
              <body style='margin:0; padding:0; text-align:center;'>
                <div id='container-decd1f4598bf4831bd5806c2f6da54ca'></div>
                <script async='async' data-cfasync='false' src='https://pl30310791.effectivecpmnetwork.com/decd1f4598bf4831bd5806c2f6da54ca/invoke.js'></script>
              </body>"
            style="width: 100%; height: 390px; border: none; scrolling: no; overflow: hidden;">
          </iframe>
        </div>

      </div>
    </aside>

  </main>
</Layout>

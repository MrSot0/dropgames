---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pedidos y Reportes | yizugames" description="Solicita un videojuego o reporta un enlace caído.">
  <div class="contenido-articulo">
    <h1>Pedidos</h1>
    <p class="intro">¿Buscas un juego que no está en el catálogo, o un enlace dejó de funcionar? Cuéntanos aquí.</p>

    <div class="aviso-pedido">
      Este sitio es 100% estático (generado con Astro, sin base de datos), así que el formulario
      abre tu cliente de correo con los datos ya redactados. Si prefieres, puedes escribir
      directamente a <a href="mailto:contacto.yizugames@gmail.com">contacto.yizugames@gmail.com</a>.
    </div>

    <form class="form-pedido" id="form-pedido">
      <div>
        <label for="tipo">Tipo de solicitud</label>
        <select id="tipo" name="tipo">
          <option value="Pedido de juego">Pedido de juego nuevo</option>
          <option value="Enlace caído">Reporte de enlace caído</option>
          <option value="Otro">Otro</option>
        </select>
      </div>

      <div>
        <label for="titulo">Título del juego</label>
        <input type="text" id="titulo" name="titulo" placeholder="Ej: Red Dead Redemption 2" required>
      </div>

      <div>
        <label for="detalle">Detalles adicionales</label>
        <textarea id="detalle" name="detalle" placeholder="Plataforma, enlace afectado, o cualquier detalle útil..."></textarea>
      </div>

      <div>
        <label for="correo">Tu correo (opcional, para avisarte)</label>
        <input type="email" id="correo" name="correo" placeholder="tucorreo@ejemplo.com">
      </div>

      <button type="submit">Enviar pedido</button>
    </form>
  </div>

  <script>
    const form = document.getElementById('form-pedido');
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const data = new FormData(form as HTMLFormElement);
      const tipo = data.get('tipo');
      const titulo = data.get('titulo');
      const detalle = data.get('detalle');
      const correo = data.get('correo');

      const asunto = encodeURIComponent(`${tipo}: ${titulo}`);
      const cuerpo = encodeURIComponent(
        `Tipo: ${tipo}\nTítulo: ${titulo}\nDetalles: ${detalle}\nCorreo de contacto: ${correo || 'no proporcionado'}`
      );

      window.location.href = `mailto:contacto.yizugames@gmail.com?subject=${asunto}&body=${cuerpo}`;
    });
  </script>
</Layout>

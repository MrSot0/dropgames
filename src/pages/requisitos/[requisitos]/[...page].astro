  </main>
</Layout>

export async function getStaticPaths({ paginate }) {
  const allGames = await getCollection('juegos');
  
  // 1. Forzamos la extracción limpia del texto. 
  // Modifica 'requisitos' por la propiedad de texto exacta de tu markdown si está anidada (ej: j.data.requisitos.nivel)
  const requisitosLista = [
    ...new Set(
      allGames.map(j => {
        if (!j.data.requisitos) return null;
        return typeof j.data.requisitos === 'object' 
          ? j.data.requisitos.nivel || j.data.requisitos.tipo 
          : j.data.requisitos;
      }).filter(Boolean)
    )
  ];

  // Generamos los paths mapeando cada uno
  return requisitosLista.flatMap((req) => {
    // Convertimos a string por seguridad y pasamos a minúsculas para evitar problemas de URL
    const reqString = String(req).toLowerCase().trim();

    const juegosFiltrados = allGames.filter(j => {
      if (!j.data.requisitos) return false;
      const nivelJuego = typeof j.data.requisitos === 'object'
        ? j.data.requisitos.nivel || j.data.requisitos.tipo
        : j.data.requisitos;
      
      return String(nivelJuego).toLowerCase().trim() === reqString;
    });

    // Validamos que realmente existan juegos para este requisito antes de paginar
    if (juegosFiltrados.length === 0) return [];

    return paginate(juegosFiltrados, { 
      params: { requisitos: reqString }, 
      pageSize: 9 
    });
  });
}

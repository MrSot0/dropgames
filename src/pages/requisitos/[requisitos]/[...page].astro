---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import GameCard from '../../../components/GameCard.astro';
import '../../../styles/global.css';

export async function getStaticPaths({ paginate }) {
  const allGames = await getCollection('juegos');
  
  // 1. Extraemos los niveles únicos directamente desde 'nivelRequisitos'
  const requisitosLista = [
    ...new Set(
      allGames.map(j => j.data.nivelRequisitos).filter(Boolean)
    )
  ];

  // 2. Generamos los paths y paginamos
  return requisitosLista.flatMap((req) => {
    const reqString = String(req).toLowerCase().trim();

    // Filtramos los juegos comparando contra su nivelRequisitos
    const juegosFiltrados = allGames.filter(j => {
      if (!j.data.nivelRequisitos) return false;
      return String(j.data.nivelRequisitos).toLowerCase().trim() === reqString;
    });

    if (juegosFiltrados.length === 0) return [];

    return paginate(juegosFiltrados, { 
      params: { requisitos: reqString }, 
      pageSize: 9 
    });
  });
}

const { requisitos } = Astro.params;
const { page } = Astro.props;

// Cambiado a capitalize para que tenga sentido con lo que hace
const capitalize = (str) => str ? str.charAt(0).toUpperCase() + str.slice(1) : '';
---

<Layout title={`Juegos para PC de requisitos ${capitalize(requisitos)} | DropGames`}>
  <main class="contenedor-principal">
    <section class="seccion-recientes">
      <h2 class="titulo-seccion">Requisitos: {capitalize(requisitos)}</h2>
      
      <div class="grid-videojuegos">
        {page.data.map((juego) => <GameCard juego={juego} />)}
      </div>

      <!-- Navegación estandarizada que va a juego con el resto de la web -->
      <nav class="pagination-ui">
        {page.url.prev && <a href={page.url.prev} class="nav-btn">«</a>}
        
        <span class="page-numbers">{page.currentPage} de {page.lastPage}</span>
        
        {page.url.next && <a href={page.url.next} class="nav-btn">»</a>}
      </nav>
    </section>

    <!-- Sidebar -->
    <aside class="sidebar-top">
      <div class="sidebar-ads">
        <!-- 🎯 ANUNCIO NATIVO 1 (Superior) -->
        <div class="ad-slot ad-sidebar-small" data-ad-label="" style="text-align: center; margin-bottom: 1rem; overflow: hidden;">
          <iframe srcdoc="
            <body style='margin:0; padding:0; text-align:center;'>
              <div id='container-decd1f4598bf4831bd5806c2f6da54ca'></div>
              <script async='async' data-cfasync='false' src='https://pl30310791.effectivecpmnetwork.com/decd1f4598bf4831bd5806c2f6da54ca/invoke.js'></script>
            </body>"
            style="width: 100%; height: 100px; border: none; scrolling: no; overflow: hidden;">
          </iframe>
        </div>

        <!-- 🎯 ANUNCIO NATIVO 2 (Medio) -->
        <div class="ad-slot ad-sidebar-rect" data-ad-label="" style="text-align: center; margin-bottom: 1rem; overflow: hidden;">
          <iframe srcdoc="
            <body style='margin:0; padding:0; text-align:center;'>
              <div id='container-decd1f4598bf4831bd5806c2f6da54ca'></div>
              <script async='async' data-cfasync='false' src='https://pl30310791.effectivecpmnetwork.com/decd1f4598bf4831bd5806c2f6da54ca/invoke.js'></script>
            </body>"
            style="width: 100%; height: 390px; border: none; scrolling: no; overflow: hidden;">
          </iframe>
        </div>
        
        <!-- 🎯 ANUNCIO NATIVO 3 (Inferior Largo) -->
        <div class="ad-slot ad-sidebar-tall" data-ad-label="" style="text-align: center; overflow: hidden;">
          <iframe srcdoc="
            <body style='margin:0; padding:0; text-align:center;'>
              <div id='container-decd1f4598bf4831bd5806c2f6da54ca'></div>
              <script async='async' data-cfasync='false' src='https://pl30310791.effectivecpmnetwork.com/decd1f4598bf4831bd5806c2f6da54ca/invoke.js'></script>
            </body>"
            style="width: 100%; height: 390px; border: none; scrolling: no; overflow: hidden;">
          </iframe>
        </div>
      </div>
    </aside>
  </main>
</Layout>

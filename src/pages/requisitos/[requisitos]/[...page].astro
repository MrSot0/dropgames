---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import GameCard from '../../../components/GameCard.astro';
import '../../../styles/global.css';

export async function getStaticPaths({ paginate }) {
  const allGames = await getCollection('juegos');
  
  // 1. EXTRAE EL STRING CORRECTO: 
  // Si 'requisitos' es un objeto, accede a la propiedad que guarda el texto (ej: j.data.requisitos.tipo o nivel)
  // Si 'requisitos' es un string en algunos juegos pero objeto en otros, asegúrate de unificarlo aquí.
  const requisitosLista = [
    ...new Set(
      allGames.map(j => {
        // Modifica esto según la estructura real de tu objeto 'requisitos'
        // Si tu objeto tiene una propiedad llamada 'nivel' (ej: j.data.requisitos.nivel), úsala aquí:
        return typeof j.data.requisitos === 'object' ? j.data.requisitos?.nivel : j.data.requisitos;
      }).filter(Boolean)
    )
  ];

  return requisitosLista.flatMap((requisitos) => {
    // 2. Filtramos comparando contra el mismo string extraído
    const juegosFiltrados = allGames.filter(j => {
      const nivelJuego = typeof j.data.requisitos === 'object' ? j.data.requisitos?.nivel : j.data.requisitos;
      return nivelJuego === requisitos;
    });
    
    // 3. Paginamos pasando el string limpio en los params
    return paginate(juegosFiltrados, { 
      params: { requisitos: String(requisitos) }, // Nos aseguramos de que sea string
      pageSize: 9 
    });
  });
}

const { requisitos } = Astro.params;
const { page } = Astro.props;

const deCapitalize = (str) => str ? str.charAt(0).toUpperCase() + str.slice(1) : '';
---

<Layout title={`Juegos para PC de requisitos ${deCapitalize(requisitos)} | DropGames`}>
  <main class="contenedor-principal">
    <section class="seccion-recientes">
      <h2 class="titulo-seccion">Requisitos: {deCapitalize(requisitos)}</h2>
      
      <div class="grid-videojuegos">
        {page.data.map((juego) => <GameCard juego={juego} />)}
      </div>

      <!-- Navegación que respeta el filtro de requisitos -->
      <nav class="pagination-ui">
        {page.url.prev && <a href={page.url.prev} class="nav-btn">« Anterior</a>}
        <span class="page-numbers">Pág {page.currentPage}</span>
        {page.url.next && <a href={page.url.next} class="nav-btn">Siguiente »</a>}
      </nav>
    </section>

    <!-- Sidebar con corrección de etiqueta de apertura -->
    <aside class="sidebar-top">
      <div class="sidebar-ads">
        <!-- 🎯 ANUNCIO NATIVO 1 (Superior) -->
        <div class="ad-slot ad-sidebar-small" data-ad-label="" style="text-align: center; margin-bottom: 1rem; overflow: hidden;">
          <iframe srcdoc="
            <body style='margin:0; padding:0; text-align:center;'>
              <div id='container-decd1f4598bf4831bd5806c2f6da54ca'></div>
              <script async='async' data-cfasync='false' src='https://pl30310791.effectivecpmnetwork.com/decd1f4598bf4831bd5806c2f6da54ca/invoke.js'></script>
            </body>"
            style="width: 100%; height: 100px; border: none; scrolling: no; overflow: hidden;">

---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';

const faqs = [
  { p: '¿Los juegos tienen virus?', r: 'No. Todos los archivos son escaneados antes de subirse. Aun así, recomendamos siempre tener un antivirus activo.' },
  { p: '¿Por qué mi antivirus marca el crack como amenaza?', r: 'Es un falso positivo común en herramientas de este tipo. Puedes agregar una excepción en tu antivirus si confías en la fuente.' },
  { p: '¿Qué hago si un enlace no funciona?', r: 'Repórtalo en la sección de Pedidos y lo revisaremos lo antes posible.' },
  { p: '¿Necesito estar registrado para descargar?', r: 'No, todas las descargas son libres y no requieren cuenta.' },
];
---

<Layout title="Ayuda y Tutoriales | DropGames" description="Guías para instalar tus juegos, saltar la publicidad de los acortadores y preguntas frecuentes.">
  <div class="contenido-articulo">
    <h1>Ayuda / Tutoriales</h1>
    <p class="intro">Guías rápidas para que tu descarga e instalación salgan sin problemas.</p>

    <section id="programas-necesarios">
      <h2>Programas Necesarios</h2>
      <div class="pasos-tutorial">
        <div class="paso-tutorial"><span class="numero"></span><p>Instala 7-Zip o WinRAR para poder extraer los archivos comprimidos.</p></div>
        <div class="paso-tutorial"><span class="numero"></span><p>Verifica que tengas instalado DirectX y las librerías de Visual C++.</p></div>
        <div class="paso-tutorial"><span class="numero"></span><p>Consulta la lista completa en la sección <a href="/programas">Programas</a>.</p></div>
      </div>
    </section>

    <section id="saltar-publicidad">
      <h2>Cómo Saltar la Publicidad</h2>
      <div class="pasos-tutorial">
        <div class="paso-tutorial"><span class="numero"></span><p>Al hacer clic en un enlace de descarga, espera a que cargue la página del acortador.</p></div>
        <div class="paso-tutorial"><span class="numero"></span><p>Busca el botón "Saltar publicidad" o el contador que aparece, generalmente arriba a la derecha.</p></div>
        <div class="paso-tutorial"><span class="numero"></span><p>Nunca descargues ni instales nada que el acortador te ofrezca fuera del enlace original.</p></div>
      </div>
    </section>

    <section id="preguntas-frecuentes">
      <h2>Preguntas Frecuentes</h2>
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>{f.p}</summary>
          <p>{f.r}</p>
        </details>
      ))}
    </section>
  </div>
</Layout>

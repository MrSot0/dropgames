---
import '../../styles/global.css';
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import GameCard from '../../components/GameCard.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Anuncio from '../../components/Anuncio.astro'; // Importamos tu componente publicitario

export async function getStaticPaths() {
  const juegos = await getCollection('juegos');
  return juegos.map((juego) => ({
    params: { slug: juego.id }, // 🎯 Mantiene la consistencia con rutas dinámicas basadas en ID
    props: { juego },
  }));
}

const { juego } = Astro.props;
const { Content } = await render(juego);
const { title, categoria, plataforma, tamano, imagen, imagenes, requisitos, enlaces, trailer } = juego.data;

const slides: string[] = imagenes && imagenes.length > 0
  ? [imagen, ...imagenes]
  : [imagen];

// 🌟 Diccionario extendido y unificado de categorías
const etiquetas: Record<string, string> = {
  accion: 'Acción',
  aventura: 'Aventura',
  rpg: 'RPG',
  deportes: 'Deportes',
  multijugador: 'Multijugador',
  estrategia: 'Estrategia',
  simulacion: 'Simulación',
  carreras: 'Carreras',
  terror: 'Terror',
  indie: 'Indie',
  peleas: 'Peleas',
  plataformas: 'Plataformas',
  shooter: 'Shooter'
};

// 🌟 Truco Dinámico: Si la categoría no está en la lista base, la capitaliza al vuelo
const categoriaFormateada = etiquetas[categoria] || (categoria.charAt(0).toUpperCase() + categoria.slice(1));

const todosLosJuegos = await getCollection('juegos');
const relacionados = todosLosJuegos
  .filter((j) => j.id !== juego.id && j.data.categoria === categoria)
  .slice(0, 3);

if (relacionados.length < 3) {
  const extras = todosLosJuegos
    .filter((j) => j.id !== juego.id && j.data.categoria !== categoria)
    .slice(0, 3 - relacionados.length);
  relacionados.push(...extras);
}
---

<Layout title={`${title} | Descargar Gratis | DropGames`} description={juego.data.descripcionCorta}>

  <div class="detalle-juego">
    <div class="detalle-contenido">

      <!-- ===== CARRUSEL DE IMÁGENES ===== -->
      <div class="detalle-carrusel" id="carrusel-principal" role="region" aria-label="Galería de imágenes">
        <div class="carrusel-pista">
          {slides.map((src, i) => (
            <div class="carrusel-slide">
              <img src={src} alt={`${title} — captura ${i + 1}`} loading={i === 0 ? 'eager' : 'lazy'}>
            </div>
          ))}
        </div>

        <button class="carrusel-btn carrusel-btn--prev" aria-label="Imagen anterior">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <button class="carrusel-btn carrusel-btn--next" aria-label="Imagen siguiente">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      </div>

      <!-- SPECS -->
      <div class="detalle-specs">
        {/* 🌟 Ahora usa la categoría mapeada o autogenerada con soporte de estilos */}
        <span class={`tag-categoria tag-categoria--${categoria}`} style="position:static;">{categoriaFormateada}</span>
        <span class="tag-plataforma">{plataforma}</span>
        <span class="tag-tamano">{tamano}</span>
      </div>

      <!-- ===== TÍTULO + BOTÓN DESCARGAR ===== -->
      <div class="detalle-cabecera-titulo">
        <h1 class="detalle-titulo">{title}</h1>
        <a
          href="#bloque-descargas"
          id="btn-descargar-principal"
          class="btn-descargar-principal"
          aria-label={`Descargar ${title}`}
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Descargar
        </a>
      </div>

      <!-- DESCRIPCIÓN -->
      <div class="detalle-descripcion">
        <Content />

        <h2>Requisitos del sistema</h2>
        <table class="tabla-requisitos">
          <thead>
            <tr><th></th><th>Mínimos</th><th>Recomendados</th></tr>
          </thead>
          <tbody>
            <tr><td>Sistema operativo</td><td>{requisitos.minimos.so}</td><td>{requisitos.recomendados.so}</td></tr>
            <tr><td>Procesador</td><td>{requisitos.minimos.cpu}</td><td>{requisitos.recomendados.cpu}</td></tr>
            <tr><td>Memoria RAM</td><td>{requisitos.minimos.ram}</td><td>{requisitos.recomendados.ram}</td></tr>
            <tr><td>Gráficos</td><td>{requisitos.minimos.gpu}</td><td>{requisitos.recomendados.gpu}</td></tr>
            <tr><td>Almacenamiento</td><td>{requisitos.minimos.almacenamiento}</td><td>{requisitos.recomendados.almacenamiento}</td></tr>
          </tbody>
        </table>
      </div>

      <!-- AD 2: Banner real entre descripción y guía (728x90) -->
      <Anuncio type="banner-728" />

      <!-- ===== GUÍA DE INSTALACIÓN ===== -->
      <div class="guia-instalacion">
        <h2>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          Guía de Instalación
        </h2>
        <ol class="pasos-tutorial">
          <li class="paso-tutorial">
            <span class="numero"></span>
            <div>
              <strong>Descarga el archivo</strong>
              <p>Haz clic en uno de los botones de descarga que se encuentran abajo. Elige el servidor de tu preferencia (MEGA, Google Drive, etc.).</p>
            </div>
          </li>
          <li class="paso-tutorial">
            <span class="numero"></span>
            <div>
              <strong>Descomprime con WinRAR o 7-Zip</strong>
              <p>Usa WinRAR o 7-Zip para extraer el archivo. Haz clic derecho sobre el archivo descargado → "Extraer aquí". Necesitarás todos los volúmenes si el juego está partido en partes.</p>
            </div>
          </li>
          <li class="paso-tutorial">
            <span class="numero"></span>
            <div>
              <strong>Monta o instala la imagen ISO</strong>
              <p>Si el archivo extraído es una imagen .ISO, móntala con WinCDEmu o Daemon Tools. Luego ejecuta el instalador dentro.</p>
            </div>
          </li>
          <li class="paso-tutorial">
            <span class="numero"></span>
            <div>
              <strong>Aplica el crack o ejecuta directamente</strong>
              <p>Copia los archivos de la carpeta "Crack" al directorio de instalación del juego (normalmente en C:\Archivos de programa). Reemplaza los existentes si se solicita.</p>
            </div>
          </li>
          <li class="paso-tutorial">
            <span class="numero"></span>
            <div>
              <strong>¡Disfruta el juego!</strong>
              <p>Ejecuta el juego como administrador si experimentas problemas al abrir. ¿Dudas? Visita nuestra sección de <a href="/ayuda" style="color: var(--acento); font-weight: 600;">Ayuda / Tutoriales</a>.</p>
            </div>
          </li>
        </ol>
      </div>

      <!-- ===== BLOQUE DE DESCARGAS ANCHOR ===== -->
      <div class="bloque-descargas" id="bloque-descargas" style="margin-top: 2rem;">
        <h3>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle;margin-right:6px;"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Enlaces de descarga
        </h3>
        <div class="lista-descargas">
          {enlaces.length > 0 ? enlaces.map((enlace) => (
            <a class="btn-descarga" href={enlace.url} target="_blank" rel="nofollow noopener">
              <span class="servidor-nombre">{enlace.servidor}</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            </a>
          )) : <p style="color: var(--texto-tenue); font-size: 0.85rem;">Próximamente disponible.</p>}
        </div>
      </div>

      <!-- 🌟 AD ADICIONAL EN CONTENIDO: Justo debajo de los enlaces de descarga (728x90) -->
      <Anuncio type="banner-728" />

      <!-- ===== TRÁILER DEL JUEGO ===== -->
      {trailer && (
        <div class="trailer-juego" style="margin-top: 2rem;">
          <h2>Tráiler de {title}</h2>
          <div class="video-contenedor" style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 8px; background: #000;">
            <iframe 
              style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0;"
              src={`https://www.youtube.com/embed/${trailer}`} 
              title={`Tráiler oficial de ${title}`}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
              allowfullscreen
            ></iframe>
          </div>
        </div>
      )}

      <!-- AD 3: Banner de cierre de contenido (728x90) -->
      <Anuncio type="banner-728" />

    </div>

    <!-- ===== SIDEBAR OPTIMIZADO ===== -->
    <aside class="detalle-sidebar" style="display: flex; flex-direction: column; gap: 2rem;">
      <Anuncio type="banner-300" />
      <Anuncio type="banner-300" />
      <Anuncio type="banner-300" />
      <Anuncio type="banner-300" />
      <Anuncio type="banner-300" />
      <Anuncio type="banner-300" />
      <Anuncio type="banner-300" />
      <Anuncio type="banner-300" />
      <Anuncio type="banner-300" />
      <Anuncio type="banner-300" />
    </aside>
  </div>

  <!-- ===== TE PODRÍA INTERESAR ===== -->
  {relacionados.length > 0 && (
    <div class="te-podria-interesar">
      <h2>Te Podría Interesar</h2>
      <div class="grid-relacionados">
        {relacionados.map((j) => <GameCard juego={j} />)}
      </div>
    </div>
  )}

</Layout>

<script>
  const pista = document.querySelector('.carrusel-pista') as HTMLElement;
  const slides = document.querySelectorAll('.carrusel-slide');
  const btnPrev = document.querySelector('.carrusel-btn--prev');
  const btnNext = document.querySelector('.carrusel-btn--next');
  
  let indexActual = 0;

  if (pista && slides.length > 0 && btnPrev && btnNext) {
    const actualizarCarrusel = () => {
      pista.style.transform = `translateX(-${indexActual * 100}%)`;
    };

    btnNext.addEventListener('click', () => {
      indexActual = (indexActual + 1) % slides.length;
      actualizarCarrusel();
    });

    btnPrev.addEventListener('click', () => {
      indexActual = (indexActual - 1 + slides.length) % slides.length;
      actualizarCarrusel();
    });
  }
</script>

---
// src/components/Anuncio.astro
interface Props {
  type?: 'banner-728' | 'banner-300' | 'nativo';
}

const { type = 'banner-728' } = Astro.props;

// Tamaño "objetivo" máximo al que queremos que se vea cada anuncio.
// El script de abajo mide el tamaño REAL que sirve la red publicitaria
// y lo escala proporcionalmente para que nunca se pase de estas medidas
// (evita que se vea deformado o gigante en el sidebar/móvil).
const limites: Record<string, { w: number; h: number }> = {
  'banner-728': { w: 728, h: 100 },
  'banner-300': { w: 260, h: 260 },
  'nativo': { w: 620, h: 300 },
};

const { w: maxW, h: maxH } = limites[type];
---

<div class={`contenedor-publicidad ad-${type}`} data-max-w={maxW} data-max-h={maxH}>
  <span class="ad-label"></span>

  <div class="ad-inner-scale">
    {type === 'banner-300' && (
      <>
        <script is:inline type="text/javascript">
          var atOptions = {
            'key' : 'f835d66e7509ed0d888e0c9c03f9e4a3',
            'format' : 'iframe',
            'height' : 250,
            'width' : 250,
            'params' : {}
          };
        </script>
        <script is:inline type="text/javascript" src="https://www.highperformanceformat.com/f835d66e7509ed0d888e0c9c03f9e4a3/invoke.js"></script>
      </>
    )}

    {type === 'banner-728' && (
      <>
        <script is:inline type="text/javascript">
          var atOptions = {
            'key' : '4be2192e6f8a94fece1b255824c14583',
            'format' : 'iframe',
            'height' : 90,
            'width' : 728,
            'params' : {}
          };
        </script>
        <script is:inline type="text/javascript" src="https://www.highperformanceformat.com/4be2192e6f8a94fece1b255824c14583/invoke.js"></script>
      </>
    )}

    {type === 'nativo' && (
      <>
        {/* 🌟 CÓDIGO NATIVO DE ADSTERRA */}
        <div id="container-tu-id-nativo"></div>
        <script is:inline async="async" data-cfasync="false" src="https://pl30310791.effectivecpmnetwork.com/decd1f4598bf4831bd5806c2f6da54ca/invoke.js"></script>
        <div id="container-decd1f4598bf4831bd5806c2f6da54ca"></div>
      </>
    )}
  </div>
</div>

<style>
  .contenedor-publicidad {
    margin: 1rem auto;
    text-align: center;
    clear: both;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .ad-label { display: block; font-size: 0.7rem; color: #666; text-transform: uppercase; letter-spacing: 0.05em; }

  /* Contenedor real del anuncio: su tamaño lo fija el JS de escalado.
     Centramos con flex para que si el recorte no es perfecto, se vea
     centrado en vez de pegado arriba-izquierda. */
  .ad-inner-scale {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    line-height: 0;
  }

  .ad-banner-728 { width: 100%; max-width: 728px; }
  .ad-banner-300 { width: 100%; max-width: 300px; }
  .ad-nativo { width: 100%; }
</style>

<script is:inline>
  (function () {
    function calcularYAplicar(wrapper, iframe) {
      const inner = wrapper.querySelector('.ad-inner-scale');
      if (!inner || !iframe) return;

      // Tamaño REAL que la red publicitaria le está dando al iframe AHORA MISMO
      const nativeW = iframe.offsetWidth;
      const nativeH = iframe.offsetHeight;
      if (!nativeW || !nativeH) return;

      const maxW = parseInt(wrapper.getAttribute('data-max-w') || '300', 10);
      const maxH = parseInt(wrapper.getAttribute('data-max-h') || '300', 10);

      // Ancho disponible real (por si el contenedor del sidebar es más chico en móvil)
      const anchoDisponible = Math.min(maxW, wrapper.clientWidth || maxW);

      // Escala proporcional: nunca deforma, solo encoge si hace falta
      const escala = Math.min(anchoDisponible / nativeW, maxH / nativeH, 1);
      if (!isFinite(escala) || escala <= 0) return;

      iframe.style.transformOrigin = 'center center';
      iframe.style.transform = `scale(${escala})`;
      inner.style.width = `${Math.round(nativeW * escala)}px`;
      inner.style.height = `${Math.round(nativeH * escala)}px`;
    }

    function vigilarIframe(wrapper, iframe) {
      if (iframe.dataset.roVigilado) return;
      iframe.dataset.roVigilado = '1';

      // ResizeObserver detecta CUALQUIER cambio de tamaño del iframe,
      // incluso si la red de anuncios lo agranda después de cargar el
      // anuncio real (algo muy común y lo que causaba el desborde).
      const ro = new ResizeObserver(() => calcularYAplicar(wrapper, iframe));
      ro.observe(iframe);

      calcularYAplicar(wrapper, iframe);
    }

    function buscarIframes() {
      document.querySelectorAll('.contenedor-publicidad').forEach((wrapper) => {
        const inner = wrapper.querySelector('.ad-inner-scale');
        const iframe = inner && inner.querySelector('iframe');
        if (iframe) vigilarIframe(wrapper, iframe);
      });
    }

    function iniciar() {
      buscarIframes();

      // El iframe puede tardar en aparecer (el script del anuncio lo
      // inyecta de forma asíncrona), así que vigilamos el DOM hasta
      // encontrarlo y engancharle el ResizeObserver.
      document.querySelectorAll('.ad-inner-scale').forEach((inner) => {
        const mo = new MutationObserver(buscarIframes);
        mo.observe(inner, { childList: true, subtree: true });
      });

      window.addEventListener('resize', buscarIframes);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', iniciar);
    } else {
      iniciar();
    }
  })();
</script>
